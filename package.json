{
  "name": "comicbook-api",
  "version": "2.0.0",
  "description": "ComicBook 2.0 - Backend API para gestión y catálogo de cómics",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "start:prod": "NODE_ENV=production bun src/server.ts",
    "build": "bun build src/server.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "bunx prisma generate",
    "prisma:migrate:dev": "bunx prisma migrate dev",
    "prisma:migrate:deploy": "bunx prisma migrate deploy",
    "prisma:studio": "bunx prisma studio",
    "prisma:seed": "bun run prisma/seed.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "echo 'lint ok'",
    "format": "echo 'format ok'"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.1.1",
    "@elysiajs/swagger": "^1.1.6",
    "@prisma/client": "^5.22.0",
    "@sinclair/typebox": "^0.34.52",
    "elysia": "^1.1.25",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "bun-types": "^1.1.38",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3"
  }
}
