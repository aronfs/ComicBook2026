meta {
  name: Update Password
  type: http
  seq: 2
}

patch {
  url: {{baseUrl}}/api/v1/users/me/password
  body: json
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{accessToken}}
}

body:json {
  {
    "currentPassword": "ChangeMe123*",
    "newPassword": "NewPassword456*"
  }
}
