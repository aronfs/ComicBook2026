meta {
  name: Refresh Token
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/auth/refresh
  body: json
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "refreshToken": "{{refreshToken}}"
  }
}

script:post-response {
  const data = res.getBody();
  if (data.success) {
    bru.setVar("accessToken", data.data.accessToken);
    bru.setVar("refreshToken", data.data.refreshToken);
  }
}
