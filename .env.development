NODE_ENV=development
HOST=0.0.0.0
PORT=3000

JWT_ACCESS_SECRET=development-access-secret-do-not-use-in-prod
JWT_REFRESH_SECRET=development-refresh-secret-do-not-use-in-prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000,http://localhost:4200,http://localhost:5173

SWAGGER_ENABLED=true
LOG_LEVEL=debug

SEED_ADMIN_EMAIL=admin@comicbook.local
SEED_ADMIN_PASSWORD=ChangeMe123*
