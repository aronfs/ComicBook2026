# Copia este archivo como .env o .env.development
# y completa los valores según tu entorno

NODE_ENV=development
HOST=0.0.0.0
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/comicbook_dev

JWT_ACCESS_SECRET=tu-access-secret-aqui
JWT_REFRESH_SECRET=tu-refresh-secret-aqui
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000

SWAGGER_ENABLED=true
LOG_LEVEL=debug

SEED_ADMIN_EMAIL=admin@comicbook.local
SEED_ADMIN_PASSWORD=ChangeMe123*
